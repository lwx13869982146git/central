<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://flowable.org/test">

    <!-- 请假申请流程 -->
    <process id="leaveRequest" name="Leave Request Process" isExecutable="true">

        <!-- 开始事件：员工提交请假申请 -->
        <startEvent id="startEvent" name="提交请假申请"/>

        <!-- 用户任务：经理审批 -->
        <userTask id="managerApproval" name="经理审批">
            <documentation>请假人: ${applicantName}, 类型: ${leaveType}, 从 ${startDate} 到 ${endDate}, 原因: ${reason}</documentation>
            <flowable:assignee expression="${applicantId}"/>
        </userTask>

        <!-- 排他网关：批准或拒绝 -->
        <exclusiveGateway id="approvalDecision" name="审批决定"/>

        <!-- 结束事件：已批准 -->
        <endEvent id="approvedEndEvent" name="请假已批准">
            <terminateEventDefinition/>
        </endEvent>

        <!-- 结束事件：已拒绝 -->
        <endEvent id="rejectedEndEvent" name="请假已拒绝">
            <terminateEventDefinition/>
        </endEvent>

        <!-- 顺序流 -->
        <sequenceFlow id="toApproval" sourceRef="startEvent" targetRef="managerApproval"/>

        <sequenceFlow id="approveFlow" sourceRef="managerApproval" targetRef="approvalDecision">
            <conditionExpression xsi:type="tFormalExpression">
                ${approved == true}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="rejectFlow" sourceRef="managerApproval" targetRef="approvalDecision">
            <conditionExpression xsi:type="tFormalExpression">
                ${approved == false}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="toApprovedEnd" sourceRef="approvalDecision" targetRef="approvedEndEvent">
            <conditionExpression xsi:type="tFormalExpression">
                ${approved == true}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="toRejectedEnd" sourceRef="approvalDecision" targetRef="rejectedEndEvent">
            <conditionExpression xsi:type="tFormalExpression">
                ${approved == false}
            </conditionExpression>
        </sequenceFlow>

    </process>

</definitions>
